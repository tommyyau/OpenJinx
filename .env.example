# OpenJinx environment variables
# Copy this file to ~/.jinx/.env and fill in your values.
# On macOS with Claude Code installed, no env vars are needed — OAuth auth is automatic.
# Tip: Run `/setup` in Claude Code to configure these interactively.

# Anthropic API key (alternative to OAuth/Keychain auth)
# ANTHROPIC_API_KEY=sk-ant-...

# Claude Code OAuth token (auto-detected from macOS Keychain if Claude Code is installed)
# CLAUDE_CODE_OAUTH_TOKEN=...

# OpenAI API key (for memory embeddings)
# OPENAI_API_KEY=sk-...

# OpenRouter API key (for web search via Perplexity Sonar)
# OPENROUTER_API_KEY=sk-or-...

# Composio API key (for external service integrations)
# COMPOSIO_API_KEY=...
